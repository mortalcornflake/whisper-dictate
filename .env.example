# Whisper Dictate Configuration
# No API key needed! Local mode works out of the box.

# === Local Transcription (default — runs on your Mac, 100% private) ===
# The installer sets these automatically. No internet or API keys required.
# WHISPER_CPP_PATH=~/whisper.cpp/build/bin/whisper-cli
# WHISPER_SERVER_PATH=~/whisper.cpp/build/bin/whisper-server
# WHISPER_MODEL_PATH=~/whisper.cpp/models/ggml-large-v3-turbo.bin

# Transcription backend: local (default), faster-whisper, groq, or openai
#   local          = whisper.cpp (macOS default, Metal-accelerated)
#   faster-whisper = faster-whisper / CTranslate2 (Windows default, CUDA-accelerated)
# DICTATE_BACKEND=local

# Enable local fallback when using a cloud backend (default: true)
# FALLBACK_TO_LOCAL=true

# === faster-whisper backend (Windows / NVIDIA, optional on macOS) ===
# Hardware is auto-detected — you do NOT need to set these. Override only if needed.
# See docs/FASTER_WHISPER.md for details.
# DICTATE_DEVICE=cuda            # force cuda | cpu (default: auto-detect)
# DICTATE_COMPUTE_TYPE=float16   # e.g. float16 | int8_float16 | int8 (default: auto)
# WHISPER_MODEL=large-v3-turbo   # model size (default: auto by VRAM)

# === Cloud Transcription (optional — for faster results) ===
# Want cloud-accelerated transcription? Get a free API key:
# Groq: https://console.groq.com (free, ~2s turnaround)
# OpenAI: https://platform.openai.com (paid, $0.006/min)
# GROQ_API_KEY=gsk_your_key_here
# OPENAI_API_KEY=sk-your_key_here
# To use cloud: uncomment the key above and set DICTATE_BACKEND=groq (or openai)

# === General Settings ===

# Optional: Pin to specific microphone (useful for using built-in mic with AirPods)
# Run: python3 -c "import sounddevice; print(sounddevice.query_devices())" to list devices
# INPUT_DEVICE=MacBook Pro Microphone

# Optional: Change hotkey (default: alt_r = Right Option)
# Options: alt_r, alt_l, option_r, option_l, ctrl_r, ctrl_l, cmd_r, cmd_l, f5, f6, f7, f8, f9, f10
# HOTKEY=alt_r

# Optional: Preserve clipboard contents after pasting (default: true)
# Set to false for faster pasting (no 0.5s delay) but clipboard will be overwritten
# PRESERVE_CLIPBOARD=true

# Optional: Auto-press Enter/Return after pasting transcription (default: false)
# Useful for sending messages immediately in chat apps or command prompts
# AUTO_PRESS_ENTER=false

# Optional: Auto-stop timeout in seconds (default: 300)
# If a recording exceeds this time, it will auto-stop and transcribe
# A warning sound plays 10 seconds before the limit
# AUTO_STOP_TIMEOUT=300

# Optional: UI sounds. PLAY_SOUNDS is the master switch (default: true).
# Each event also has its own toggle, defaulting to PLAY_SOUNDS, so you can keep
# just the ones you want. On macOS you can also flip these live from the menu
# bar's "Sounds" submenu (it writes your choice back here).
#   SOUND_START   - when recording starts   (macOS: Tink)
#   SOUND_STOP    - when recording stops     (macOS: Blow)
#   SOUND_DONE    - when transcription pastes (macOS: Glass)
#   SOUND_WARNING - ~10s before auto-stop    (macOS: Sosumi)
# PLAY_SOUNDS=true
# SOUND_START=true
# SOUND_STOP=false
# SOUND_DONE=false
# SOUND_WARNING=true
