# ============================================================================
# Whisper Dictate — settings template
# ----------------------------------------------------------------------------
# Copy this file to ".env" and edit it (the installer does this for you):
#     cp .env.example .env
# This file IS the settings screen. Edit a value, save, then restart the app.
# Lines starting with '#' are comments/examples and are ignored — a setting only
# takes effect as an uncommented NAME=value line. Anything left commented uses
# the built-in default shown in its description.
#
# No API key needed! Local mode works out of the box.
# ============================================================================


# ─── Transcription backend ──────────────────────────────────────────────────
# WHERE your speech is turned into text. This is the main switch.
#   local          → whisper.cpp on your own machine. 100% private, offline, free.
#                    (default — uses the WHISPER_* paths below.)
#   groq           → Groq cloud API. Fastest (~2s), generous free tier. Needs
#                    GROQ_API_KEY set below. (Some VPNs block api.groq.com.)
#   openai         → OpenAI cloud API. Paid (~$0.006/min). Needs OPENAI_API_KEY.
#   faster-whisper → local GPU backend (NVIDIA/CUDA). Windows default.
#
# To use a cloud backend: fill in the matching key further down, then set e.g.
#     DICTATE_BACKEND=groq
# Leave this commented for the default (local).
# DICTATE_BACKEND=local

# If a cloud backend (groq/openai) fails or times out, fall back to local
# whisper.cpp instead of erroring. Recommended: true. (Ignored when backend=local.)
# FALLBACK_TO_LOCAL=true


# ─── Local backend (whisper.cpp) paths ──────────────────────────────────────
# The installer fills these in automatically. Only set them by hand if you
# installed/moved whisper.cpp yourself. Used when DICTATE_BACKEND=local (and for
# fallback from a cloud backend).
# WHISPER_CPP_PATH=~/whisper.cpp/build/bin/whisper-cli
# WHISPER_SERVER_PATH=~/whisper.cpp/build/bin/whisper-server
# WHISPER_MODEL_PATH=~/whisper.cpp/models/ggml-large-v3-turbo.bin


# ─── faster-whisper backend (Windows / NVIDIA; optional on macOS) ────────────
# Hardware is auto-detected — you do NOT normally need these. Override only if
# the auto-pick is wrong. See docs/FASTER_WHISPER.md.
# DICTATE_DEVICE=cuda            # force cuda | cpu (default: auto-detect)
# DICTATE_COMPUTE_TYPE=float16   # e.g. float16 | int8_float16 | int8 (default: auto)
# WHISPER_MODEL=large-v3-turbo   # model size (default: auto by VRAM)


# ─── Cloud API keys ─────────────────────────────────────────────────────────
# Only used when DICTATE_BACKEND is groq or openai. Uncomment and paste your key.
#   Groq (free):   https://console.groq.com   → key starts with  gsk_
#   OpenAI (paid): https://platform.openai.com → key starts with  sk-
# GROQ_API_KEY=gsk_your_key_here
# OPENAI_API_KEY=sk-your_key_here


# ─── Microphone ─────────────────────────────────────────────────────────────
# Pin recording to a specific mic (e.g. dictate on the built-in mic while
# listening on Bluetooth headphones). Must match a device name exactly.
# List devices:  python3 -c "import sounddevice; print(sounddevice.query_devices())"
# Leave commented to use the system default input.
# INPUT_DEVICE=MacBook Pro Microphone


# ─── Hotkey ─────────────────────────────────────────────────────────────────
# The key you hold/press to dictate. Default: Right Option on macOS (alt_r),
# Right Control on Windows (ctrl_r).
# Valid options: alt_r, alt_l, option_r, option_l, ctrl_r, ctrl_l, cmd_r, cmd_l,
#                f5, f6, f7, f8, f9, f10
# (option_r/option_l are macOS-friendly aliases for alt_r/alt_l.)
# HOTKEY=alt_r


# ─── Hands-free (latched) recording ─────────────────────────────────────────
# Normally you hold the hotkey while speaking. Hands-free lets you START a
# recording by holding a modifier (default: Shift) AND tapping the hotkey — then
# let go of everything and keep talking. Tap the hotkey again (on its own) to
# stop. Great for longer, hands-off dictation. On macOS this is also a checkbox
# in the menu bar. Default: on.
# HANDS_FREE=true
# Modifier held with the hotkey to latch: shift (default), ctrl, cmd, or alt.
# (Don't pick the same family as your hotkey.)
# HANDS_FREE_MODIFIER=shift


# ─── Pasting behaviour ──────────────────────────────────────────────────────
# Save and restore your clipboard around each paste so dictating doesn't clobber
# what you had copied. true = safer (adds ~0.5s); false = faster but overwrites.
# PRESERVE_CLIPBOARD=true

# Automatically press Enter/Return right after pasting (e.g. to send a chat
# message or run a command immediately). true/false.
# AUTO_PRESS_ENTER=false


# ─── Auto-stop safety net ───────────────────────────────────────────────────
# Max length of a single recording, in seconds, before it auto-stops and
# transcribes (protects against a "stuck" recording). Default: 300 (5 min).
# A warning sound (see SOUND_WARNING) plays 10s before this limit.
# AUTO_STOP_TIMEOUT=300


# ─── UI sounds (per-event) ──────────────────────────────────────────────────
# Each sound is independent — set to true/false. PLAY_SOUNDS is a master switch
# (set it false to mute everything). Each event also has its own toggle, which
# defaults to PLAY_SOUNDS, so you can keep just the ones you want. On macOS you
# can also flip these live from the menu bar's "Sounds" submenu (it writes your
# choice back into this file).
#   SOUND_START   – when recording starts        (macOS sound: Tink)
#   SOUND_STOP    – when recording stops          (macOS sound: Blow)
#   SOUND_DONE    – when transcription is pasted   (macOS sound: Glass)
#   SOUND_WARNING – ~10s before auto-stop limit    (macOS sound: Sosumi)
# PLAY_SOUNDS=true
# SOUND_START=true
# SOUND_STOP=false
# SOUND_DONE=false
# SOUND_WARNING=true
